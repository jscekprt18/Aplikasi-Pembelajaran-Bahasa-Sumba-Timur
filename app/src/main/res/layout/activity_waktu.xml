<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WaktuActivity"
    android:background="@drawable/new4">

    <ImageButton
        android:id="@+id/besok"
        android:layout_width="150dp"
        android:layout_marginStart="50dp"
        android:layout_height="137dp"
        android:layout_marginTop="62dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/besok1"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="10dp"

        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/kemarin"
        android:layout_width="150dp"
        android:layout_height="137dp"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="62dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/kemarin"

        app:layout_constraintLeft_toRightOf="@id/besok"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/pagi"
        android:layout_width="150dp"
        android:layout_height="137dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/pagi"
        android:layout_marginStart="50dp"
        app:layout_constraintTop_toBottomOf="@id/besok"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteX="16dp" />


    <ImageButton
        android:id="@+id/siang"
        android:layout_width="150dp"
        android:layout_height="137dp"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/siang"
        app:layout_constraintLeft_toRightOf="@id/pagi"
        app:layout_constraintTop_toBottomOf="@id/kemarin" />

    <ImageButton
        android:id="@+id/sore"
        android:layout_width="150dp"
        android:layout_height="137dp"
        android:scaleType="centerCrop"
        android:background="@android:color/transparent"
        android:src="@drawable/sore"
        app:layout_constraintTop_toBottomOf="@id/pagi"
        android:layout_marginTop="12dp"
        android:layout_marginStart="50dp"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/malam"
        android:layout_width="150dp"
        android:layout_height="137dp"
        android:scaleType="centerCrop"
        android:background="@android:color/transparent"
        android:src="@drawable/malam"
        app:layout_constraintTop_toBottomOf="@id/siang"
        app:layout_constraintLeft_toRightOf="@id/sore"
        android:layout_marginTop="12dp" />

    <ImageButton
        android:id="@+id/balik4"
        android:layout_width="90dp"
        android:layout_height="40dp"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="40dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/mmundur"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.21"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sore" />


</androidx.constraintlayout.widget.ConstraintLayout>