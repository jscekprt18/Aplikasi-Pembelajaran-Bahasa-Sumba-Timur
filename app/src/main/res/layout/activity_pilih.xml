<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PilihActivity"
    android:background="@drawable/new5">

    <ImageButton
        android:id="@+id/home"
        android:layout_width="50dp"
        android:layout_height="40dp"
        android:layout_marginStart="48dp"
        android:layout_marginBottom="132dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/h"
        app:layout_constraintBottom_toTopOf="@id/Belajar"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/Informasi"
        android:layout_width="50dp"
        android:layout_height="40dp"
        android:layout_marginEnd="36dp"
        android:layout_marginBottom="132dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/i"
        app:layout_constraintBottom_toTopOf="@id/Belajar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintLeft_toRightOf="@id/Informasi" />

    <ImageButton
        android:id="@+id/Belajar"
        android:layout_width="200dp"
        android:layout_height="120dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/nbelajar"
        app:layout_constraintBottom_toTopOf="@+id/Kuis"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.625"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.922" />

    <ImageButton
        android:id="@+id/Kuis"
        android:layout_width="200dp"
        android:layout_height="120dp"
        android:layout_marginBottom="180dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/nkuis"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.625"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>