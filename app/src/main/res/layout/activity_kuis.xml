<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".KuisActivity"
    android:background="@drawable/xxx">


    <TextView
        android:id="@+id/skorTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="60dp"
        android:fontFamily="@font/gentysans"
        android:text="Skor: 0"
        android:textColor="#C70039"
        android:textSize="30sp"
        app:layout_constraintBottom_toTopOf="@id/pertanyaantxt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.115"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.247" />


    <TextView
        android:id="@+id/pertanyaantxt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="228dp"
        android:fontFamily="@font/gentysans"
        android:gravity="center"
        android:text="pertanyaan kuis?"
        android:textColor="#22A9F4"
        android:textSize="25sp"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="0dp" />

    <Button
        android:id="@+id/opsi1btn"
        android:layout_width="160dp"
        android:layout_height="65dp"
        android:layout_below="@+id/pertanyaantxt"
        android:layout_marginStart="36dp"
        android:layout_marginTop="136dp"
        android:fontFamily="@font/gentysans"
        android:text="Opsi 1"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pertanyaantxt" />

    <Button
        android:id="@+id/opsi2btn"
        android:layout_width="160dp"
        android:layout_height="65dp"
        android:layout_below="@+id/opsi1btn"
        android:layout_marginTop="136dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/gentysans"
        android:text="Opsi 2"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintLeft_toRightOf="@id/opsi1btn"
        app:layout_constraintTop_toBottomOf="@id/pertanyaantxt" />

    <ImageView
        android:id="@+id/sedih"
        android:layout_width="201dp"
        android:layout_height="206dp"
        android:layout_marginTop="152dp"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.509"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pertanyaantxt"
        app:srcCompat="@drawable/sad" />

    <ImageView
        android:id="@+id/senang"
        android:layout_width="180dp"
        android:layout_height="204dp"
        android:layout_marginTop="152dp"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.509"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pertanyaantxt"
        app:srcCompat="@drawable/happy" />


    <ImageButton
        android:id="@+id/kembalii"
        android:layout_width="90dp"
        android:layout_height="40dp"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="40dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/mmundur"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.184"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/senang" />


</androidx.constraintlayout.widget.ConstraintLayout>