<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AngkaActivity"
    android:background="@drawable/new4">



    <ImageButton
        android:id="@+id/satu"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="78dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/satu"
        tools:layout_editor_absoluteY="33dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="20dp"/>

    <ImageButton
        android:id="@+id/dua"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="4dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/dua"
        app:layout_constraintLeft_toRightOf="@+id/satu"
        tools:layout_editor_absoluteY="33dp"
        app:layout_constraintStart_toEndOf="@+id/satu"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="20dp"/>

    <ImageButton
        android:id="@+id/tiga"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="78dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/tiga"
        app:layout_constraintTop_toBottomOf="@id/satu"
        tools:layout_editor_absoluteX="4dp"
        app:layout_constraintStart_toStartOf="parent"/>


    <ImageButton
        android:id="@+id/empat"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/empat"
        app:layout_constraintLeft_toRightOf="@id/tiga"
        app:layout_constraintTop_toBottomOf="@id/dua" />

    <ImageButton
        android:id="@+id/lima"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="78dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/lima"
        app:layout_constraintTop_toBottomOf="@id/tiga"
        tools:layout_editor_absoluteX="10dp"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/enam"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/enam"
        app:layout_constraintLeft_toRightOf="@id/lima"
        app:layout_constraintTop_toBottomOf="@id/empat" />

    <ImageButton
        android:id="@+id/tujuh"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="78dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/tuju"
        app:layout_constraintTop_toBottomOf="@id/lima"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteX="16dp" />


    <ImageButton
        android:id="@+id/delapan"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/depan"
        app:layout_constraintLeft_toRightOf="@id/tujuh"
        app:layout_constraintTop_toBottomOf="@id/enam" />

    <ImageButton
        android:id="@+id/sembilan"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="78dp"
        android:scaleType="centerCrop"
        android:background="@android:color/transparent"
        android:src="@drawable/sembilan"
        app:layout_constraintTop_toBottomOf="@id/tujuh"
        android:layout_marginTop="5dp"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/sepuluh"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:scaleType="centerCrop"
        android:background="@android:color/transparent"
        android:src="@drawable/puluh"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/delapan"
        app:layout_constraintLeft_toRightOf="@id/sembilan"
        android:layout_marginLeft="4dp"/>

    <ImageButton
        android:id="@+id/kembalii"
        android:layout_width="90dp"
        android:layout_height="40dp"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="40dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/mmundur"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.184"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sembilan" />
</androidx.constraintlayout.widget.ConstraintLayout>