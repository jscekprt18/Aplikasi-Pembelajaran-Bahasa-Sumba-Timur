<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AlamActivity"
    android:background="@drawable/ff">

    <ImageButton
        android:id="@+id/matahari"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginStart="78dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/matahari"
        tools:layout_editor_absoluteY="33dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="40dp"/>

    <ImageButton
        android:id="@+id/bulan"
        android:layout_width="120dp"
        android:layout_height="150dp"

        android:layout_marginStart="4dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/bulan"
        app:layout_constraintLeft_toRightOf="@+id/matahari"
        tools:layout_editor_absoluteY="33dp"
        app:layout_constraintStart_toEndOf="@+id/matahari"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="40dp"/>


    <ImageButton
        android:id="@+id/bintang"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginStart="78dp"
        android:layout_marginTop="4dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/bintang"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/matahari" />

    <ImageButton
        android:id="@+id/angin"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/angin"
        app:layout_constraintLeft_toRightOf="@id/bintang"
        app:layout_constraintTop_toBottomOf="@id/bulan" />

    <ImageButton
        android:id="@+id/panas"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginStart="78dp"
        android:layout_marginTop="4dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/panas"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bintang" />

    <ImageButton
        android:id="@+id/dingin"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="4dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/dingin"
        app:layout_constraintLeft_toRightOf="@id/panas"
        app:layout_constraintTop_toBottomOf="@id/angin" />


    <ImageButton
        android:id="@+id/hujan"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginStart="78dp"
        android:layout_marginTop="4dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/hujan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/panas" />

    <ImageButton
        android:id="@+id/balik2"
        android:layout_width="90dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/mmundur"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.093"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hujan"
        app:layout_constraintVertical_bias="0.88"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="40dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>