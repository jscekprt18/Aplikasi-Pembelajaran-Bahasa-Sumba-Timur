<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".BelajarActivity4"
    android:background="@drawable/new5">



    <ImageButton
        android:id="@+id/waktu"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="78dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/nwaktu"
        tools:layout_editor_absoluteX="2dp"
        tools:layout_editor_absoluteY="33dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="250dp"/>

    <ImageButton
        android:id="@+id/kata"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="4dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/norg"
        app:layout_constraintLeft_toRightOf="@+id/waktu"
        tools:layout_editor_absoluteY="33dp"
        app:layout_constraintStart_toEndOf="@+id/waktu"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="250dp"/>

    <ImageButton
        android:id="@+id/cerita"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginStart="78dp"
        android:layout_marginTop="2dp"

        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/ncerita"
        app:layout_constraintTop_toBottomOf="@id/waktu"
        tools:layout_editor_absoluteX="4dp"
        app:layout_constraintStart_toStartOf="parent"/>


    <ImageButton
        android:id="@+id/seni"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="2dp"
        android:layout_marginStart="4dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/nseni"
        app:layout_constraintLeft_toRightOf="@id/cerita"
        app:layout_constraintTop_toBottomOf="@id/kata" />

    <ImageButton
        android:id="@+id/kmbl"
        android:layout_width="90dp"
        android:layout_height="40dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="112dp"
        android:layout_marginEnd="40dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/mmundur"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.146"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cerita" />

</androidx.constraintlayout.widget.ConstraintLayout>