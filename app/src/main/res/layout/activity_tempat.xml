<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TempatActivity"
    android:background="@drawable/new4">

    <ImageButton
        android:id="@+id/sungai"
        android:layout_width="120dp"
        android:layout_height="130dp"
        android:layout_marginStart="100dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/sungai"
        tools:layout_editor_absoluteY="33dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="30dp"/>

    <ImageButton
        android:id="@+id/laut"
        android:layout_width="120dp"
        android:layout_height="130dp"
        android:layout_marginStart="4dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/laut"
        app:layout_constraintLeft_toRightOf="@+id/sungai"
        tools:layout_editor_absoluteY="33dp"
        app:layout_constraintStart_toEndOf="@+id/sungai"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="30dp"/>

    <ImageButton
        android:id="@+id/gunung"
        android:layout_width="120dp"
        android:layout_height="130dp"
        android:layout_marginStart="100dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/gunung"
        app:layout_constraintTop_toBottomOf="@id/sungai"
        tools:layout_editor_absoluteX="4dp"
        app:layout_constraintStart_toStartOf="parent"/>


    <ImageButton
        android:id="@+id/hutan"
        android:layout_width="120dp"
        android:layout_height="130dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/hutan"
        app:layout_constraintLeft_toRightOf="@id/gunung"
        app:layout_constraintTop_toBottomOf="@id/laut" />

    <ImageButton
        android:id="@+id/lembah"
        android:layout_width="120dp"
        android:layout_height="130dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:layout_marginStart="100dp"
        android:src="@drawable/lembah"
        app:layout_constraintTop_toBottomOf="@id/gunung"
        tools:layout_editor_absoluteX="10dp"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageButton
        android:id="@+id/jalan"
        android:layout_width="120dp"
        android:layout_height="130dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/jalan"
        app:layout_constraintLeft_toRightOf="@id/lembah"
        app:layout_constraintTop_toBottomOf="@id/hutan" />

    <ImageButton
        android:id="@+id/sekolah"
        android:layout_width="120dp"
        android:layout_height="130dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:layout_marginStart="100dp"
        android:src="@drawable/sekolah"
        app:layout_constraintTop_toBottomOf="@id/lembah"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteX="16dp" />


    <ImageButton
        android:id="@+id/rumah"
        android:layout_width="120dp"
        android:layout_height="130dp"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="5dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/rumah"
        app:layout_constraintLeft_toRightOf="@id/sekolah"
        app:layout_constraintTop_toBottomOf="@id/jalan" />


    <ImageButton
        android:id="@+id/balik3"
        android:layout_width="90dp"
        android:layout_height="40dp"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="40dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/mmundur"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.18"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rumah" />


</androidx.constraintlayout.widget.ConstraintLayout>