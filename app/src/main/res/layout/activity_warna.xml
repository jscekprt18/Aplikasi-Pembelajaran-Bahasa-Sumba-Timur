<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WarnaActivity"
    android:background="@drawable/xx1">


    <ImageButton
        android:id="@+id/merah"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:background="@android:color/transparent"
        android:src="@drawable/merah"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/kuning"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="65dp"/>

    <ImageButton
        android:id="@+id/kuning"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:background="@android:color/transparent"
        android:src="@drawable/kuning"
        app:layout_constraintStart_toEndOf="@id/merah"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="65dp"/>


    <ImageButton
        android:id="@+id/biru"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:background="@android:color/transparent"
        android:src="@drawable/biru"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/hijau"
        app:layout_constraintTop_toBottomOf="@id/merah" />

    <ImageButton
        android:id="@+id/hijau"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:background="@android:color/transparent"
        android:src="@drawable/hijau"
        app:layout_constraintStart_toEndOf="@id/biru"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/kuning" />


    <ImageButton
        android:id="@+id/hitam"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        android:src="@drawable/hitam"
        app:layout_constraintEnd_toStartOf="@id/putih"
        app:layout_constraintTop_toBottomOf="@id/biru" />

    <ImageButton
        android:id="@+id/putih"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:background="@android:color/transparent"
        android:src="@drawable/putih"
        app:layout_constraintStart_toEndOf="@id/hitam"
        app:layout_constraintEnd_toEndOf="parent"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toBottomOf="@id/hijau" />


    <ImageButton
        android:id="@+id/balik"
        android:layout_width="90dp"
        android:layout_height="40dp"
        android:layout_marginTop="20dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/mmundur"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.121"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hitam" />

</androidx.constraintlayout.widget.ConstraintLayout>