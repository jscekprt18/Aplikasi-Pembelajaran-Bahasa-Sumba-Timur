<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AktifActivity2"
    android:background="@drawable/new4">



    <ImageButton
        android:id="@+id/bljr"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginStart="78dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/belajar"
        tools:layout_editor_absoluteY="33dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="65dp"/>

    <ImageButton
        android:id="@+id/bcr"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginStart="4dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/bicara"
        app:layout_constraintLeft_toRightOf="@+id/bljr"
        tools:layout_editor_absoluteY="33dp"
        app:layout_constraintStart_toEndOf="@+id/bljr"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="65dp"/>

    <ImageButton
        android:id="@+id/lari"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/lari"
        app:layout_constraintTop_toBottomOf="@id/bcr"
        tools:layout_editor_absoluteX="4dp"
        android:layout_marginStart="78dp"
        app:layout_constraintStart_toStartOf="parent"/>


    <ImageButton
        android:id="@+id/main"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/main"
        app:layout_constraintLeft_toRightOf="@id/lari"
        app:layout_constraintTop_toBottomOf="@id/bcr" />

    <ImageButton
        android:id="@+id/mdn"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/mandi"
        app:layout_constraintTop_toBottomOf="@id/lari"
        tools:layout_editor_absoluteX="10dp"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="78dp"/>

    <ImageButton
        android:id="@+id/msk"
        android:layout_width="120dp"
        android:layout_height="150dp"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/masak"
        app:layout_constraintLeft_toRightOf="@id/mdn"
        app:layout_constraintTop_toBottomOf="@id/main" />



    <ImageButton
        android:id="@+id/kmbl90"
        android:layout_width="90dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:scaleType="centerCrop"
        android:src="@drawable/mmundur"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.093"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mdn"
        app:layout_constraintVertical_bias="0.88"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="40dp"/>


</androidx.constraintlayout.widget.ConstraintLayout>